DJANGO_SECRET_KEY=change-this-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
ALLOWED_REGISTRATION_DOMAINS=bestfinance.com.np
SIGNUP_LINK_MAX_AGE_SECONDS=86400
AD_AUTH_ENABLED=False
AD_ONLY_LOGIN=False
LOCAL_ACCOUNT_SELF_SERVICE_ENABLED=True
LOCAL_RECOVERY_SUPERUSERS=admin
AD_SERVER_HOST=
# Optional: comma-separated domain controllers for failover, e.g. dc1.example.local,dc2.example.local
AD_SERVER_HOSTS=
AD_SERVER_PORT=389
AD_USE_SSL=False
AD_VALIDATE_CERTS=True
AD_CA_CERT_FILE=
AD_CONNECT_TIMEOUT=5
AD_RECEIVE_TIMEOUT=10
AD_BASE_DN=DC=example,DC=local
AD_USER_SEARCH_BASE=OU=Users,DC=example,DC=local
AD_BIND_DN=CN=ldap-reader,OU=Service Accounts,DC=example,DC=local
# If the password contains $, write it as $$ in this file for docker compose.
AD_BIND_PASSWORD=
AD_LOGIN_ATTR=sAMAccountName
AD_USER_PRINCIPAL_ATTR=userPrincipalName
AD_USERNAME_ATTR=sAMAccountName
AD_EMAIL_ATTR=mail
AD_FIRST_NAME_ATTR=givenName
AD_LAST_NAME_ATTR=sn
AD_DEPARTMENT_ATTR=department
AD_POSITION_ATTR=title
AD_BRANCH_ATTR=physicalDeliveryOfficeName
AD_GROUP_ATTR=memberOf
AD_ALLOWED_GROUP_DN=
AD_STAFF_GROUP_DN=
AD_ITSUPPORT_GROUP_DN=
USE_REDIS_CHANNEL_LAYER=False
REDIS_URL=redis://127.0.0.1:6379/0

POSTGRES_DB=helpdeskdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=True
SMTP_FROM_EMAIL=

DEFAULT_FROM_EMAIL=helpdesk@bestfinance.com.np
IT_SUPPORT_EMAIL=helpdesk@bestfinance.com.np
SITE_URL=http://127.0.0.1:8000
MESSAGE_RETENTION_DAYS=20

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_BUCKET=bestsupport-media
TICKET_ATTACHMENT_MAX_SIZE_MB=20

# WebRTC ICE servers for ticket audio calls.
# Leave WEBRTC_STUN_URLS / WEBRTC_TURN_URLS blank to auto-use the same host as the app.
WEBRTC_STUN_URLS=
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_PASSWORD=
WEBRTC_TURN_AUTH_SECRET=change-turn-shared-secret
WEBRTC_TURN_CREDENTIAL_TTL_SECONDS=3600
WEBRTC_TURN_CREDENTIAL_TYPE=
WEBRTC_USE_HOST_TURN_FALLBACK=True
WEBRTC_STUN_PORT=3478
WEBRTC_TURN_PORT=3478
WEBRTC_TURNS_PORT=5349

# Coturn service settings for docker-compose.yml
# Set TURN_EXTERNAL_IP to the same IP where the application is hosted.
# For intranet deployment, use the app server's intranet IP.
TURN_REALM=helpdesk.local
TURN_EXTERNAL_IP=
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
TURN_USERNAME=
TURN_PASSWORD=
TURN_AUTH_SECRET=

# Option 2: full JSON override for multiple ICE servers/credential types
# WEBRTC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turns:turn.example.com:5349?transport=tcp"],"username":"turnuser","credential":"turnpassword"}]
